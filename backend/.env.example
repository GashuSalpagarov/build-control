# ===========================================
# Build Control Backend - Environment
# ===========================================

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/build_control?schema=public"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# File Uploads
UPLOAD_DIR="../uploads"
MAX_FILE_SIZE=52428800
